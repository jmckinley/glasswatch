# Glasswatch Backend Configuration

# Database
DATABASE_URL=postgresql+asyncpg://glasswatch:glasswatch-secret@localhost:5432/glasswatch

# Redis Cache
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Environment
ENV=development
DEBUG=true

# External APIs (optional)
# NVD_API_KEY=your-nvd-api-key
# EPSS_API_URL=https://api.first.org/data/v1/epss

# WorkOS (for production auth)
# WORKOS_API_KEY=your-workos-api-key
# WORKOS_CLIENT_ID=your-workos-client-id

# AWS (for KMS encryption)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# Snapper Runtime Integration
# SNAPPER_API_URL=https://api.snapper.io
# SNAPPER_API_KEY=your-snapper-key