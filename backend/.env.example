# Glasswatch Backend Environment Variables

# Database
DATABASE_URL=postgresql+asyncpg://glasswatch:glasswatch@localhost:5432/glasswatch

# Redis
REDIS_URL=redis://localhost:6379/0

# Memgraph (Graph Database)
MEMGRAPH_URL=bolt://localhost:7687

# Security
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-change-in-production

# External APIs (Optional)
ANTHROPIC_API_KEY=
VULNCHECK_API_KEY=
SNAPPER_API_URL=
SNAPPER_API_KEY=

# ServiceNow Integration (Optional)
SERVICENOW_INSTANCE=
SERVICENOW_USERNAME=
SERVICENOW_PASSWORD=

# Jira Integration (Optional)  
JIRA_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# AWS (Optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# WorkOS Auth (Future)
WORKOS_API_KEY=
WORKOS_CLIENT_ID=