# Glasswatch Production Environment Template
# Copy to .env.production and fill in real values
# NEVER commit .env.production to version control!

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_NAME=glasswatch
DATABASE_USER=glasswatch
DATABASE_PASSWORD=REPLACE_WITH_STRONG_PASSWORD  # Generate: openssl rand -base64 32
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# =============================================================================
# APPLICATION SECURITY
# =============================================================================
SECRET_KEY=REPLACE_WITH_SECRET_KEY  # Generate: openssl rand -hex 32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# BACKUP
# =============================================================================
BACKUP_DIR=/var/backups/glasswatch
BACKUP_S3_BUCKET=your-backup-bucket-name
BACKUP_ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY  # Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# =============================================================================
# AWS (Optional - for S3 backups, KMS, etc.)
# =============================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=REPLACE_OR_USE_IAM_ROLES
AWS_SECRET_ACCESS_KEY=REPLACE_OR_USE_IAM_ROLES

# =============================================================================
# WORKOS (Optional - for SSO)
# =============================================================================
WORKOS_API_KEY=REPLACE_IF_USING_SSO
WORKOS_CLIENT_ID=REPLACE_IF_USING_SSO

# =============================================================================
# CORS
# =============================================================================
BACKEND_CORS_ORIGINS=https://app.glasswatch.example.com,https://glasswatch.example.com

# =============================================================================
# EXTERNAL APIs (Optional)
# =============================================================================
NVD_API_KEY=REPLACE_IF_AVAILABLE
SNAPPER_API_KEY=REPLACE_IF_USING

# =============================================================================
# FEATURES
# =============================================================================
PATCH_WEATHER_ENABLED=true
PATCH_WEATHER_MIN_REPORTS=5

# =============================================================================
# OPTIMIZATION
# =============================================================================
OPTIMIZATION_MAX_TIME_SECONDS=30
OPTIMIZATION_DEFAULT_WINDOWS=12

# =============================================================================
# ENVIRONMENT
# =============================================================================
ENV=production
DEBUG=false
PROJECT_NAME=Glasswatch
VERSION=1.0.0

# =============================================================================
# DATA DIRECTORY (for Docker Compose deployments)
# =============================================================================
DATA_DIR=/opt/glasswatch/data
